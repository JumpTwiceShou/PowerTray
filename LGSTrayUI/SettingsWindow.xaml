<Window x:Class="LGSTrayUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LGSTrayUI"
        mc:Ignorable="d"
        Title="PowerTray"
        Width="{Binding WindowWidth, Mode=OneTime}"
        Height="{Binding WindowHeight, Mode=OneTime}"
        MinWidth="{Binding WindowMinWidth, Mode=OneTime}"
        MinHeight="{Binding WindowMinHeight, Mode=OneTime}"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="{DynamicResource UIFontFamily}"
        FontSize="{DynamicResource UIFontSize}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource UIFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource UIFontSize}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="{DynamicResource UIButtonMinHeight}"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,4,8,4"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource UIFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource UIFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="{DynamicResource UIInputMinHeight}"/>
            <Setter Property="Margin" Value="0,4,8,4"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource UIFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource UIFontSize}"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TextBoxBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AliasTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="{DynamicResource UIDeviceAliasPadding}"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="ModernTextMenuItem" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource UIFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource UIMenuFontSize}"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MinWidth" Value="154"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Margin="0,1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <Grid MinWidth="{TemplateBinding MinWidth}"
                                  Height="{TemplateBinding MinHeight}"
                                  Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MenuHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}"/>
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextSeparator" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Margin="8,4"
                                Background="{DynamicResource MenuSeparatorBrush}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ModernTextMenuItem}"/>
        </Style>

        <ControlTemplate x:Key="DiagnosticsScrollThumbTemplate" TargetType="Thumb">
            <Border x:Name="ThumbBorder"
                    Margin="2"
                    CornerRadius="4"
                    Background="#9AA3AE"/>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ThumbBorder" Property="Background" Value="#748091"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DiagnosticsScrollRepeatButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DiagnosticsVerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{TemplateBinding Background}" Width="{TemplateBinding Width}">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource DiagnosticsScrollRepeatButton}"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb MinHeight="36" Template="{StaticResource DiagnosticsScrollThumbTemplate}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource DiagnosticsScrollRepeatButton}"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="DiagnosticsHorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{TemplateBinding Background}" Height="{TemplateBinding Height}">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Style="{StaticResource DiagnosticsScrollRepeatButton}"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb MinWidth="36" Template="{StaticResource DiagnosticsScrollThumbTemplate}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Style="{StaticResource DiagnosticsScrollRepeatButton}"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style x:Key="DiagnosticsScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="9"/>
            <Setter Property="MinWidth" Value="9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template" Value="{StaticResource DiagnosticsVerticalScrollBarTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="Height" Value="9"/>
                    <Setter Property="MinHeight" Value="9"/>
                    <Setter Property="Template" Value="{StaticResource DiagnosticsHorizontalScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="{DynamicResource UIComboItemMinHeight}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource UIFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource UIFontSize}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="{DynamicResource UIInputMinHeight}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource UIFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource UIFontSize}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="7">
                                            <Grid>
                                                <ContentPresenter x:Name="ContentSite"
                                                                  Margin="10,0,34,0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True"/>
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Width="8"
                                                      Height="4"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"
                                                      Fill="{DynamicResource MutedTextBrush}"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="10,0,34,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource MenuBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,6,0,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource UIFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource UIFontSize}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box"
                                    Width="19"
                                    Height="19"
                                    CornerRadius="6"
                                    BorderThickness="1.5"
                                    BorderBrush="{DynamicResource InputBorderBrush}"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    Margin="0,0,8,0">
                                <Path x:Name="CheckMark"
                                      Data="M 4 9 L 8 13 L 14 5"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="SliderDecreaseButtonTemplate" TargetType="{x:Type RepeatButton}">
            <Border Height="6"
                    VerticalAlignment="Center"
                    Background="{DynamicResource AccentBrush}"
                    CornerRadius="3"/>
        </ControlTemplate>

        <ControlTemplate x:Key="SliderIncreaseButtonTemplate" TargetType="{x:Type RepeatButton}">
            <Border Height="6"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SliderTrackBrush}"
                    CornerRadius="3"/>
        </ControlTemplate>

        <ControlTemplate x:Key="SliderThumbTemplate" TargetType="{x:Type Thumb}">
            <Grid Width="28" Height="28" ClipToBounds="False">
                <Border x:Name="ThumbBorder"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="2"
                        CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.28"/>
                    </Border.Effect>
                </Border>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
                    <Setter TargetName="ThumbBorder" Property="Width" Value="22"/>
                    <Setter TargetName="ThumbBorder" Property="Height" Value="22"/>
                    <Setter TargetName="ThumbBorder" Property="CornerRadius" Value="11"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Margin="0,6" ClipToBounds="False">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Focusable="False"
                                                  Template="{StaticResource SliderDecreaseButtonTemplate}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="28"
                                           Height="28"
                                           Template="{StaticResource SliderThumbTemplate}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Focusable="False"
                                                  Template="{StaticResource SliderIncreaseButtonTemplate}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Width" Value="148"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Width" Value="132"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource UIFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource UIFontSize}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="NavBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource NavigationHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavigationSelectedTextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="DevicePanelBorder" TargetType="Border" BasedOn="{StaticResource PanelBorder}">
            <Setter Property="Padding" Value="18,10"/>
        </Style>

        <Style x:Key="PercentBadge" TargetType="Border">
            <Setter Property="MinWidth" Value="{DynamicResource UIPercentBadgeWidth}"/>
            <Setter Property="Height" Value="{DynamicResource UIPercentBadgeHeight}"/>
            <Setter Property="Background" Value="{DynamicResource BadgeBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BadgeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource UIPercentBadgeCornerRadius}"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MetaPill" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MetaPillBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="PageScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="22,18,0,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Loc[SettingsTitle]}" FontSize="{DynamicResource UIPageTitleFontSize}" FontWeight="SemiBold" Margin="0,0,0,14"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="148"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="SettingsNavigation" SelectedIndex="0">
                <ListBoxItem Content="{Binding Loc[NavGeneral]}"/>
                <ListBoxItem Content="{Binding Loc[NavAlerts]}"/>
                <ListBoxItem Content="{Binding Loc[NavDevices]}"/>
                <ListBoxItem Content="{Binding Loc[NavDiagnostics]}"/>
            </ListBox>

            <Grid Grid.Column="1" Margin="16,0,0,0">
                <ScrollViewer>
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DiagnosticsScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer" BasedOn="{StaticResource PageScrollViewer}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsNavigation}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel Margin="0,0,22,0">
                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[Language]}" FontSize="{DynamicResource UISectionTitleFontSize}" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding LanguageOptions}"
                                          SelectedValue="{Binding Language, Mode=TwoWay}"
                                          SelectedValuePath="Code"
                                          TextSearch.TextPath="NativeName"
                                          Width="{DynamicResource UISettingsComboWidth}"
                                          Margin="0,10,0,10"
                                          HorizontalAlignment="Left">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding NativeName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="{Binding Loc[Theme]}" FontSize="{DynamicResource UISectionTitleFontSize}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <ComboBox SelectedValue="{Binding ThemeMode, Mode=TwoWay}" SelectedValuePath="Tag" Width="{DynamicResource UISettingsComboWidth}" Margin="0,10,0,10" HorizontalAlignment="Left">
                                    <ComboBoxItem Tag="system" Content="{Binding Loc[ThemeSystem]}"/>
                                    <ComboBoxItem Tag="light" Content="{Binding Loc[ThemeLight]}"/>
                                    <ComboBoxItem Tag="dark" Content="{Binding Loc[ThemeDark]}"/>
                                </ComboBox>
                                <TextBlock Text="{Binding Loc[UiScale]}" FontSize="{DynamicResource UISectionTitleFontSize}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <StackPanel Width="444" Margin="0,10,0,12" HorizontalAlignment="Left">
                                    <Slider x:Name="UiScaleSlider"
                                            Width="388"
                                            HorizontalAlignment="Left"
                                            Minimum="0"
                                            Maximum="3"
                                            IsSnapToTickEnabled="False"
                                            IsMoveToPointEnabled="True"
                                            SmallChange="1"
                                            LargeChange="1"
                                            Focusable="True"
                                            PreviewMouseLeftButtonUp="OnUiScaleMouseLeftButtonUp"
                                            TouchUp="OnUiScaleTouchUp"
                                            KeyUp="OnUiScaleKeyUp"
                                            LostFocus="OnUiScaleLostFocus"
                                            Value="{Binding UiScaleValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Canvas Width="360" Height="12" Margin="14,-2,0,0" HorizontalAlignment="Left">
                                        <Line X1="0" Y1="0" X2="0" Y2="9" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"/>
                                        <Line X1="60" Y1="2" X2="60" Y2="7" Stroke="{DynamicResource SliderTrackBrush}" StrokeThickness="2"/>
                                        <Line X1="120" Y1="0" X2="120" Y2="9" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"/>
                                        <Line X1="180" Y1="2" X2="180" Y2="7" Stroke="{DynamicResource SliderTrackBrush}" StrokeThickness="2"/>
                                        <Line X1="240" Y1="0" X2="240" Y2="9" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"/>
                                        <Line X1="300" Y1="2" X2="300" Y2="7" Stroke="{DynamicResource SliderTrackBrush}" StrokeThickness="2"/>
                                        <Line X1="360" Y1="0" X2="360" Y2="9" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"/>
                                    </Canvas>
                                    <Canvas Width="430" Height="34" Margin="14,0,0,0" HorizontalAlignment="Left">
                                        <TextBlock Canvas.Left="-65" Width="130" Text="{Binding Loc[UiScaleSmall]}" TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="{DynamicResource UIScaleSmallLabelFontSize}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedUiScaleCode}" Value="small">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Canvas.Left="55" Width="130" Text="{Binding Loc[UiScaleStandard]}" TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="{DynamicResource UIScaleStandardLabelFontSize}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedUiScaleCode}" Value="standard">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Canvas.Left="175" Width="130" Text="{Binding Loc[UiScaleLarge]}" TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="{DynamicResource UIScaleLargeLabelFontSize}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedUiScaleCode}" Value="large">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Canvas.Left="295" Width="130" Text="{Binding Loc[UiScaleMaximum]}" TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="{DynamicResource UIScaleMaximumLabelFontSize}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedUiScaleCode}" Value="maximum">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Canvas>
                                </StackPanel>
                                <CheckBox Content="{Binding Loc[StartWithWindows]}" IsChecked="{Binding AutoStart}"/>
                                <CheckBox Content="{Binding Loc[AutoCheckUpdates]}" IsChecked="{Binding AutoCheckUpdates}"/>
                                <CheckBox Content="{Binding Loc[NumericIcon]}" IsChecked="{Binding NumericDisplay}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer>
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DiagnosticsScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer" BasedOn="{StaticResource PageScrollViewer}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsNavigation}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel Margin="0,0,22,0">
                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[GlobalDefaults]}" FontSize="{DynamicResource UISectionTitleFontSize}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Loc[DefaultThreshold]}" Margin="0,12,0,2"/>
                                <Grid Width="{DynamicResource UIThresholdControlWidth}" HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Loaded="OnThresholdSliderLoaded"
                                            Unloaded="OnThresholdSliderUnloaded"
                                            Minimum="1"
                                            Maximum="100"
                                            TickFrequency="1"
                                            IsMoveToPointEnabled="True"
                                            PreviewMouseLeftButtonUp="OnThresholdMouseLeftButtonUp"
                                            TouchUp="OnThresholdTouchUp"
                                            KeyUp="OnThresholdKeyUp"
                                            LostFocus="OnThresholdLostFocus"
                                            Value="{Binding DefaultThresholdPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Border Grid.Column="1" Style="{StaticResource PercentBadge}" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding DefaultThresholdPercentText}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <CheckBox Content="{Binding Loc[WindowsNotification]}" IsChecked="{Binding DefaultWindowsNotification}"/>
                                <CheckBox Content="{Binding Loc[TrayBlink]}" IsChecked="{Binding DefaultTrayBlink}"/>
                                <CheckBox Content="{Binding Loc[SuppressFullscreen]}" IsChecked="{Binding SuppressNotificationsWhenFullscreen}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[QuietHours]}" FontSize="{DynamicResource UISectionTitleFontSize}" FontWeight="SemiBold"/>
                                <CheckBox Content="{Binding Loc[QuietHoursEnabled]}" IsChecked="{Binding QuietHoursEnabled}"/>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Width="120">
                                        <TextBlock Text="{Binding Loc[QuietStart]}"/>
                                        <TextBox Text="{Binding QuietHoursStart, UpdateSourceTrigger=LostFocus}"/>
                                    </StackPanel>
                                    <StackPanel Width="120">
                                        <TextBlock Text="{Binding Loc[QuietEnd]}"/>
                                        <TextBox Text="{Binding QuietHoursEnd, UpdateSourceTrigger=LostFocus}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer>
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DiagnosticsScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer" BasedOn="{StaticResource PageScrollViewer}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsNavigation}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel Margin="0,0,13,0">
                        <TextBlock Text="{Binding Loc[NoDevices]}" Visibility="{Binding DeviceItems.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}"/>
                        <ItemsControl ItemsSource="{Binding DeviceItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DevicePanelBorder}">
                                            <StackPanel>
                                                <Grid HorizontalAlignment="Left" VerticalAlignment="Center" MinHeight="{DynamicResource UIButtonMinHeight}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Height="{DynamicResource UIButtonMinHeight}" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" MaxWidth="{DynamicResource UIDeviceTitleMaxWidth}" FontSize="{DynamicResource UISectionTitleFontSize}" LineHeight="{DynamicResource UIDeviceTitleLineHeight}" LineStackingStrategy="BlockLineHeight" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Border Grid.Column="1" Style="{StaticResource MetaPill}" Padding="8,3" Margin="6,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding Loc[Offline]}" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource UICaptionFontSize}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                                    </Border>
                                                    <Button Grid.Column="2"
                                                            Content="{Binding Loc[RemoveHistory]}"
                                                            Command="{Binding RemoveHistoryCommand}"
                                                            Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            Height="{DynamicResource UIButtonMinHeight}"
                                                            Margin="18,0,0,0"
                                                            Padding="10,0"
                                                            VerticalAlignment="Center"/>
                                                </Grid>
                                            <TextBlock Visibility="{Binding ShowOriginalName, Converter={StaticResource BoolToVisibilityConverter}}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding Loc[OriginalName], Mode=OneWay}"/>
                                                <Run Text=": "/>
                                                <Run Text="{Binding OriginalName, Mode=OneWay}"/>
                                            </TextBlock>
                                            <Grid Margin="0,14,0,0" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="{DynamicResource UIDeviceThresholdColumnGap}"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Column="0" Width="{DynamicResource UIDeviceFieldWidth}">
                                                    <TextBlock Text="{Binding Loc[Alias]}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Loc[AliasHint]}" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource UICaptionFontSize}" Margin="0,2,0,6" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="0"
                                                         Style="{StaticResource AliasTextBox}"
                                                         Width="{DynamicResource UIDeviceFieldWidth}"
                                                         Height="{DynamicResource UIInputMinHeight}"
                                                         MinHeight="{DynamicResource UIInputMinHeight}"
                                                         VerticalAlignment="Top"
                                                         PreviewTextInput="OnAliasPreviewTextInput"
                                                         DataObject.Pasting="OnAliasPasting"
                                                         Text="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"/>

                                                <TextBlock Grid.Column="2" Text="{Binding Loc[LowBatteryThreshold]}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
                                                <StackPanel Grid.Row="1" Grid.Column="2" Width="{DynamicResource UIDeviceThresholdControlWidth}" Margin="0,-4,0,0">
                                                    <CheckBox Content="{Binding Loc[FollowGlobalThreshold]}"
                                                              IsChecked="{Binding FollowGlobalThreshold}"
                                                              Margin="0,-2,0,0"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Slider Grid.Column="0"
                                                                Loaded="OnThresholdSliderLoaded"
                                                                Unloaded="OnThresholdSliderUnloaded"
                                                                Minimum="1"
                                                                Maximum="100"
                                                                TickFrequency="1"
                                                                IsMoveToPointEnabled="True"
                                                                IsEnabled="{Binding IsCustomThreshold}"
                                                                PreviewMouseLeftButtonUp="OnThresholdMouseLeftButtonUp"
                                                                TouchUp="OnThresholdTouchUp"
                                                                KeyUp="OnThresholdKeyUp"
                                                                LostFocus="OnThresholdLostFocus"
                                                                Value="{Binding ThresholdPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <Border Grid.Column="1" Style="{StaticResource PercentBadge}" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding ThresholdPercentText}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel Margin="0,12,0,0" Visibility="{Binding ShowBatteryMetadata, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Border Style="{StaticResource MetaPill}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Loc[Battery], StringFormat={}{0}:}" Foreground="{DynamicResource MutedTextBrush}"/>
                                                        <TextBlock Text="{Binding BatteryText}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource MetaPill}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Loc[LastUpdate], StringFormat={}{0}:}" Foreground="{DynamicResource MutedTextBrush}"/>
                                                        <TextBlock Text="{Binding LastUpdateText}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                            <Grid Margin="0,8,0,0" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="{DynamicResource UIDeviceOptionColumnGap}"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <CheckBox Grid.Row="0" Grid.Column="0" IsChecked="{Binding FollowGlobalNumericDisplay}" Width="{DynamicResource UIDeviceOptionColumnWidth}" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Loc[FollowGlobalNumericIcon]}" TextWrapping="Wrap"/>
                                                </CheckBox>
                                                <CheckBox Grid.Row="0" Grid.Column="2" IsChecked="{Binding WindowsNotification}" Width="{DynamicResource UIDeviceOptionColumnWidth}" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Loc[WindowsNotification]}" TextWrapping="Wrap"/>
                                                </CheckBox>
                                                <CheckBox Grid.Row="1" Grid.Column="0" IsChecked="{Binding NumericDisplay}" IsEnabled="{Binding IsCustomNumericDisplay}" Width="{DynamicResource UIDeviceOptionColumnWidth}" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Loc[NumericIcon]}" TextWrapping="Wrap"/>
                                                </CheckBox>
                                                <CheckBox Grid.Row="1" Grid.Column="2" IsChecked="{Binding TrayBlink}" Width="{DynamicResource UIDeviceOptionColumnWidth}" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Loc[TrayBlink]}" TextWrapping="Wrap"/>
                                                </CheckBox>
                                            </Grid>
                                            <WrapPanel>
                                                <Button Content="{Binding Loc[PauseOneHour]}" Command="{Binding PauseOneHourCommand}"/>
                                                <Button Content="{Binding Loc[PauseUntilNextLaunch]}" Command="{Binding PauseUntilNextLaunchCommand}"/>
                                                <Button Content="{Binding Loc[ResumeAlerts]}" Command="{Binding ResumeAlertsCommand}"/>
                                                <TextBlock Text="{Binding PauseText}" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" Margin="8,0,0,0"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <Grid Margin="0,0,22,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsNavigation}" Value="3">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding Loc[Diagnostics]}" FontSize="{DynamicResource UISectionTitleFontSize}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Loc[ReleaseVersion], StringFormat={}{0}:}" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding CurrentVersion}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Loc[GHubStatus], StringFormat={}{0}:}"/>
                            <TextBlock Text="{Binding GHubStatus}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Loc[Port9010Status], StringFormat={}{0}:}" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding Port9010Status}" FontWeight="SemiBold"/>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="{Binding Loc[RefreshDiagnostics]}" Command="{Binding RefreshDiagnosticsCommand}"/>
                                <Button Content="{Binding Loc[ExportDiagnostics]}" Command="{Binding ExportDiagnosticsCommand}"/>
                                <Button Content="{Binding Loc[MenuCheckUpdates]}" Command="{Binding CheckForUpdatesCommand}"/>
                                <Button Content="{Binding Loc[TestNotification]}" Command="{Binding TestNotificationCommand}"/>
                                <Button Content="{Binding Loc[TestBlink]}" Command="{Binding TestBlinkAllCommand}"/>
                                <Button Content="{Binding Loc[StopBlink]}" Command="{Binding StopBlinkCommand}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="0" Margin="0">
                        <TextBox Text="{Binding DiagnosticSummary}"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Margin="0"
                                 Padding="{DynamicResource UIDiagnosticsTextPadding}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontFamily="Consolas"
                                 FontSize="{DynamicResource UIMonospaceFontSize}">
                            <TextBox.ContextMenu>
                                <ContextMenu Style="{StaticResource ModernTextContextMenu}">
                                    <ContextMenu.Resources>
                                        <Style TargetType="Separator" BasedOn="{StaticResource ModernTextSeparator}"/>
                                    </ContextMenu.Resources>
                                    <MenuItem Header="{Binding PlacementTarget.DataContext.Loc[ContextCut], RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              InputGestureText="Ctrl+X"
                                              Command="{x:Static ApplicationCommands.Cut}"
                                              CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{Binding PlacementTarget.DataContext.Loc[ContextCopy], RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              InputGestureText="Ctrl+C"
                                              Command="{x:Static ApplicationCommands.Copy}"
                                              CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{Binding PlacementTarget.DataContext.Loc[ContextPaste], RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              InputGestureText="Ctrl+V"
                                              Command="{x:Static ApplicationCommands.Paste}"
                                              CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="{Binding PlacementTarget.DataContext.Loc[ContextSelectAll], RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              InputGestureText="Ctrl+A"
                                              Command="{x:Static ApplicationCommands.SelectAll}"
                                              CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </TextBox.ContextMenu>
                            <TextBox.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource DiagnosticsScrollBarStyle}"/>
                            </TextBox.Resources>
                        </TextBox>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
