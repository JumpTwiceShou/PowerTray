<Window x:Class="LGSTrayUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LGSTrayUI"
        mc:Ignorable="d"
        Title="{Binding Loc[SettingsTitle]}"
        Width="940"
        Height="660"
        MinWidth="840"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F8">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MutedSurfaceBrush" Color="#EEF2F7"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D7DEE8"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="0,4,8,4"/>
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="BorderBrush" Value="#C7D2FE"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#BFDBFE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Margin" Value="0,4,8,4"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,6,0,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="5"
                                    BorderThickness="1.5"
                                    BorderBrush="#9CA3AF"
                                    Background="White"
                                    Margin="0,0,8,0">
                                <Path x:Name="CheckMark"
                                      Data="M 4 9 L 8 13 L 14 5"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="SliderDecreaseButtonTemplate" TargetType="{x:Type RepeatButton}">
            <Border Height="6"
                    VerticalAlignment="Center"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="3"/>
        </ControlTemplate>

        <ControlTemplate x:Key="SliderIncreaseButtonTemplate" TargetType="{x:Type RepeatButton}">
            <Border Height="6"
                    VerticalAlignment="Center"
                    Background="#DCE4EF"
                    CornerRadius="3"/>
        </ControlTemplate>

        <ControlTemplate x:Key="SliderThumbTemplate" TargetType="{x:Type Thumb}">
            <Border x:Name="ThumbBorder"
                    Width="20"
                    Height="20"
                    Background="White"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#64748B" BlurRadius="7" ShadowDepth="1" Opacity="0.22"/>
                </Border.Effect>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ThumbBorder" Property="Background" Value="#EFF6FF"/>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter TargetName="ThumbBorder" Property="Background" Value="#DBEAFE"/>
                    <Setter TargetName="ThumbBorder" Property="Width" Value="22"/>
                    <Setter TargetName="ThumbBorder" Property="Height" Value="22"/>
                    <Setter TargetName="ThumbBorder" Property="CornerRadius" Value="11"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Margin="0,4">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Focusable="False"
                                                  Template="{StaticResource SliderDecreaseButtonTemplate}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="20"
                                           Height="20"
                                           Template="{StaticResource SliderThumbTemplate}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Focusable="False"
                                                  Template="{StaticResource SliderIncreaseButtonTemplate}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Width" Value="132"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="NavBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#E8EEF7"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="PercentBadge" TargetType="Border">
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MetaPill" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Loc[SettingsTitle]}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18"/>

        <TabControl Grid.Row="1" TabStripPlacement="Left" Background="Transparent" BorderThickness="0">
            <TabItem Header="{Binding Loc[NavGeneral]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,0,0,0">
                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[Language]}" FontSize="16" FontWeight="SemiBold"/>
                                <ComboBox SelectedValue="{Binding Language, Mode=TwoWay}" SelectedValuePath="Tag" Width="260" Margin="0,10,0,0" HorizontalAlignment="Left">
                                    <ComboBoxItem Tag="en-US" Content="{Binding Loc[English]}"/>
                                    <ComboBoxItem Tag="zh-CN" Content="{Binding Loc[Chinese]}"/>
                                </ComboBox>
                                <CheckBox Content="{Binding Loc[StartWithWindows]}" IsChecked="{Binding AutoStart}"/>
                                <CheckBox Content="{Binding Loc[NumericIcon]}" IsChecked="{Binding NumericDisplay}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding Loc[NavAlerts]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,0,0,0">
                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[GlobalDefaults]}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Loc[DefaultThreshold]}" Margin="0,12,0,2"/>
                                <Grid Width="390" HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="66"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Minimum="1"
                                            Maximum="100"
                                            TickFrequency="1"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding DefaultThresholdPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Border Grid.Column="1" Style="{StaticResource PercentBadge}" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding DefaultThresholdPercentText}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <CheckBox Content="{Binding Loc[WindowsNotification]}" IsChecked="{Binding DefaultWindowsNotification}"/>
                                <CheckBox Content="{Binding Loc[TrayBlink]}" IsChecked="{Binding DefaultTrayBlink}"/>
                                <CheckBox Content="{Binding Loc[SuppressFullscreen]}" IsChecked="{Binding SuppressNotificationsWhenFullscreen}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[QuietHours]}" FontSize="16" FontWeight="SemiBold"/>
                                <CheckBox Content="{Binding Loc[QuietHoursEnabled]}" IsChecked="{Binding QuietHoursEnabled}"/>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Width="120">
                                        <TextBlock Text="{Binding Loc[QuietStart]}"/>
                                        <TextBox Text="{Binding QuietHoursStart, UpdateSourceTrigger=LostFocus}"/>
                                    </StackPanel>
                                    <StackPanel Width="120">
                                        <TextBlock Text="{Binding Loc[QuietEnd]}"/>
                                        <TextBox Text="{Binding QuietHoursEnd, UpdateSourceTrigger=LostFocus}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding Loc[NavDevices]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,0,0,0">
                        <TextBlock Text="{Binding Loc[NoDevices]}" Visibility="{Binding DeviceItems.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}"/>
                        <ItemsControl ItemsSource="{Binding DeviceItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PanelBorder}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="17" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding OriginalName, StringFormat={}{0}}" Foreground="#6B7280"/>
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="230"/>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Loc[Alias]}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Loc[AliasHint]}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,6"/>
                                                </StackPanel>
                                                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"/>

                                                <TextBlock Grid.Column="2" Text="{Binding Loc[Threshold]}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                                <StackPanel Grid.Row="1" Grid.Column="2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="66"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Slider Grid.Column="0"
                                                                Minimum="1"
                                                                Maximum="100"
                                                                TickFrequency="1"
                                                                IsMoveToPointEnabled="True"
                                                                Value="{Binding ThresholdPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <Border Grid.Column="1" Style="{StaticResource PercentBadge}" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding ThresholdPercentText}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel Margin="0,12,0,0">
                                                <Border Style="{StaticResource MetaPill}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Loc[Battery], StringFormat={}{0}:}" Foreground="{StaticResource MutedTextBrush}"/>
                                                        <TextBlock Text="{Binding BatteryText}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource MetaPill}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Loc[LastUpdate], StringFormat={}{0}:}" Foreground="{StaticResource MutedTextBrush}"/>
                                                        <TextBlock Text="{Binding LastUpdateText}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                            <CheckBox Content="{Binding Loc[WindowsNotification]}" IsChecked="{Binding WindowsNotification}"/>
                                            <CheckBox Content="{Binding Loc[TrayBlink]}" IsChecked="{Binding TrayBlink}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Button Content="{Binding Loc[TestNotification]}" Command="{Binding TestNotificationCommand}"/>
                                                <Button Content="{Binding Loc[TestBlink]}" Command="{Binding TestBlinkCommand}"/>
                                                <Button Content="{Binding Loc[RestoreDefaults]}" Command="{Binding RestoreDefaultsCommand}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{Binding Loc[PauseOneHour]}" Command="{Binding PauseOneHourCommand}"/>
                                                <Button Content="{Binding Loc[PauseToday]}" Command="{Binding PauseTodayCommand}"/>
                                                <Button Content="{Binding Loc[ResumeAlerts]}" Command="{Binding ResumeAlertsCommand}"/>
                                                <TextBlock Text="{Binding PauseText}" VerticalAlignment="Center" Foreground="#6B7280" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding Loc[NavDiagnostics]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,0,0,0">
                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[Diagnostics]}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Loc[GHubStatus], StringFormat={}{0}:}"/>
                                <TextBlock Text="{Binding GHubStatus}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Loc[Port9010Status], StringFormat={}{0}:}" Margin="0,8,0,0"/>
                                <TextBlock Text="{Binding Port9010Status}" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="{Binding Loc[RefreshDiagnostics]}" Command="{Binding RefreshDiagnosticsCommand}"/>
                                    <Button Content="{Binding Loc[ExportDiagnostics]}" Command="{Binding ExportDiagnosticsCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <TextBox Text="{Binding DiagnosticSummary}" AcceptsReturn="True" IsReadOnly="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Height="320" FontFamily="Consolas"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
